    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "drizzle-orm": "^0.35.0",
    "pg": "^8.13.0",
    "adhan": "^4.4.0",
    "zod": "^3.23.0",
    "@aws-sdk/client-s3": "^3.650.0",
    "@myathan/shared": "*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "drizzle-kit": "^0.26.0",
    "@types/pg": "^8.11.0",
    "@types/node": "^22.0.0"
  }
