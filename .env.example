# MyAthan Core — Environment Variables

# Database
DATABASE_URL=postgresql://myathan:myathan@localhost:5432/myathan

# JWT
JWT_SECRET=change-me-in-production

# Cloudflare R2
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_BUCKET=myathan

# Admin Seed Credentials (API only)
# Set these to auto-create the initial admin account on first deploy.
# The account will have mustChangePassword=true — change credentials after first login.
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-me-in-production

# Server
PORT=3000
HOST=0.0.0.0
